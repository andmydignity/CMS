<!DOCTYPE html>
<html lang="en">

<head>
  <meta name="color-scheme" content="light dark">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
  {{if .FaviconPath}}
  <link rel="icon" type="image/x-icon" href={{.FaviconPath}}>
  {{end}}

  {{template "commonCSS" .}}
  {{template "commonJS" .}}
  <style>
    /* ── Home Page Layout ───────────────────────────────────────────────── */
    .home-header {
      margin-bottom: 2.5rem;
    }

    .home-header h1 {
      margin-top: 0;
      font-size: 2.5rem;
      letter-spacing: -.03em;
    }

    /* Search Bar */
    .search-bar {
      margin-top: 1.5rem;
      position: relative;
      width: 100%;
      max-width: 450px;
    }

    .search-bar svg {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
      flex-shrink: 0;
    }

    .search-bar input {
      width: 100%;
      padding: 0.75rem 1.15rem 0.75rem 2.75rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-alt);
      color: var(--text);
      font-family: var(--font-serif);
      font-size: 1rem;
      transition: border-color var(--ease), box-shadow var(--ease);
      box-sizing: border-box;
    }

    .search-bar input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* Search Status & Helpers */
    .search-status {
      margin-top: 0;
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      min-height: 1.25em;
      text-align: left;
    }

    #search-sentinel {
      width: 100%;
      height: 20px;
      visibility: hidden;
    }

    /* Card Grid */
    .page-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    @media (min-width: 600px) {
      .page-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (min-width: 900px) {
      .page-grid {
        grid-template-columns: repeat(5, 1fr);
      }
    }

    .content {
      max-width: 1200px;
    }

     .page-card {
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      text-decoration: none !important;
      color: inherit;
      transition: transform var(--ease), box-shadow var(--ease), border-color var(--ease);
    }

    .page-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
      border-color: var(--accent);
    }

    :root[data-theme="dark"] .page-card:hover {
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
    }

    .card-image {
      width: 100%;
      height: 150px;
      border-bottom: 1px solid var(--border);
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      margin: 0;
      border: none;
      border-radius: 0;
    }

    .card-content {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .card-content h2 {
      font-size: 1.25rem;
      margin-top: 0;
      margin-bottom: 0.5rem;
      border-bottom: none;
      padding-bottom: 0;
      color: var(--text);
      transition: color var(--ease);
    }

    .page-card:hover .card-content h2 {
      color: var(--accent);
    }

    .card-content .overview {
      font-size: 0.925rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
      line-height: 1.6;
      flex-grow: 1;
    }

    .card-meta {
      margin-top: auto;
      font-size: 0.8rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
    }

    .no-pages, .no-results {
      grid-column: 1 / -1;
      padding: 2.5rem;
      text-align: center;
      color: var(--text-muted);
      background: var(--bg-alt);
      border-radius: var(--radius);
      border: 1px dashed var(--border);
    }
  </style>

  <script>
    (function () {
      "use strict";

      const MIN_CHARS = 3;
      const BATCH_SIZE = 20;

      // 1. Inject JSON array of ALL pages for instant searching
      const allPages = [
        {{range .AllPages}}{
          url: {{.URL}},
          title: {{.Title}},
          img: {{.ImgPath}},
          overview: {{.OverviewText}},
          date: {{.ModifiedAt}}
        },{{end}}
      ];

      document.addEventListener("DOMContentLoaded", function () {
        const input = document.getElementById("page-search");
        const latestPostsContainer = document.getElementById("latest-posts");
        const searchResultsContainer = document.getElementById("search-results-container");
        const grid = document.getElementById("page-grid");
        const status = document.getElementById("search-status");
        const sentinel = document.getElementById("search-sentinel");
        const noResults = document.getElementById("no-results");

        if (!input || !grid || !latestPostsContainer) return;

        let filteredPages = [];
        let currentIndex = 0;

        const renderCard = (p) => {
          const imgHtml = p.img ? `<div class="card-image"><img src="${p.img}" alt="${p.title}" loading="lazy"></div>` : '';
          return `
            <a href="${p.url}" class="page-card">
              ${imgHtml}
              <div class="card-content">
                <h2>${p.title}</h2>
                <p class="overview">${p.overview}</p>
                <div class="card-meta">
                  <span class="date">Updated: ${p.date}</span>
                </div>
              </div>
            </a>`;
        };

        const loadNextBatch = () => {
          const nextBatch = filteredPages.slice(currentIndex, currentIndex + BATCH_SIZE);
          if (nextBatch.length === 0) return;

          const fragment = document.createDocumentFragment();
          nextBatch.forEach(p => {
            const temp = document.createElement('div');
            temp.innerHTML = renderCard(p);
            fragment.appendChild(temp.firstElementChild);
          });
          
          grid.appendChild(fragment);
          currentIndex += nextBatch.length;
        };

        const observer = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting && filteredPages.length > currentIndex) {
            loadNextBatch();
          }
        }, { rootMargin: '200px' });

        if (sentinel) observer.observe(sentinel);

        input.addEventListener("input", function (e) {
          const raw = e.target.value;
          const query = raw.toLowerCase().trim();

          // 2. Revert to Static View if query is too short
          if (query.length < MIN_CHARS) {
            latestPostsContainer.style.display = "block";
            searchResultsContainer.style.display = "none";
            grid.innerHTML = '';
            status.textContent = "";
            return;
          }

          // 3. Switch to Dynamic View
          latestPostsContainer.style.display = "none";
          searchResultsContainer.style.display = "block";

          filteredPages = allPages.filter(p => 
            p.title.toLowerCase().includes(query) || 
            p.overview.toLowerCase().includes(query)
          );

          currentIndex = 0;
          grid.innerHTML = '';

          // 4. Handle Results state
          if (filteredPages.length === 0) {
            noResults.style.display = "block";
            sentinel.style.display = "none";
            status.textContent = "";
          } else {
            noResults.style.display = "none";
            sentinel.style.display = "block";
            loadNextBatch();
            status.textContent = `${filteredPages.length} ${filteredPages.length === 1 ? 'result' : 'results'} for '${raw.trim()}'`;
          }
        });
      });
    })();
  </script>

  {{if .Style}}
  <link rel="stylesheet" href="/assets/style/{{.Style}}.css">
  {{end}}
  {{if .Script}}
  <script src="/assets/style/{{.Script}}.js"></script>
  {{end}}
</head>

<body>
  <div class="navbar">
    {{block "navbar" .}}{{end}}
  </div>

  <main class="content">
    {{block "content" .}}{{.Content}}{{end}}
  </main>

  <footer class="footer">
    {{block "footer" .}}{{end}}
  </footer>
</body>

</html>
