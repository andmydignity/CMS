<!DOCTYPE html>
<html lang="en">

<head>
  <meta name="color-scheme" content="light dark">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search — {{if .SiteName}}{{.SiteName}}{{else}}MySite{{end}}</title>
  {{if .FaviconPath}}
  <link rel="icon" type="image/x-icon" href={{.FaviconPath}}>
  {{end}}

  <link rel="stylesheet" href="/assets/style/common.css">
  <script src="/assets/style/common.js"></script>
  <style>
    /* Search Page Layout */
    .content {
      max-width: 1200px;
    }

    /* Hero section */
    .search-hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 0 2.5rem;
      width: 100%;
      box-sizing: border-box;
      gap: 1.5rem;
    }

    .search-hero h1 {
      margin: 0;
      font-size: 2.25rem;
      letter-spacing: -.03em;
    }

    .search-hero p {
      margin: 0;
      color: var(--text-muted);
      font-size: 1rem;
    }

    /* Search input */
    .search-bar {
      width: 100%;
      max-width: 520px;
      margin: 0;
      position: relative;
    }

    .search-bar svg {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      pointer-events: none;
      flex-shrink: 0;
    }

    .search-bar input {
      width: 100%;
      padding: 0.85rem 1.15rem 0.85rem 2.75rem;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-alt);
      color: var(--text);
      font-family: var(--font-serif);
      font-size: 1.05rem;
      transition: border-color var(--ease), box-shadow var(--ease);
      box-sizing: border-box;
    }

    .search-bar input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    /* Result count hint */
    .search-status {
      margin-top: 0;
      margin-bottom: 1.25rem;
      font-size: 0.875rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      min-height: 1.25em;
      text-align: center;
    }

    /* Card grid — Converted to Flexbox to center incomplete rows */
    .page-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
    }

    /* Exact width calculations for 2, 3, and 5 columns */
    .page-card {
      width: calc(50% - 0.75rem); /* Default: 2 columns */
      display: flex;
      flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      text-decoration: none !important;
      color: inherit;
      transition: transform var(--ease), box-shadow var(--ease), border-color var(--ease);
    }

    @media (min-width: 600px) {
      .page-card {
        width: calc(33.333% - 1rem); /* Tablet: 3 columns */
      }
    }

    @media (min-width: 900px) {
      .page-card {
        width: calc(20% - 1.2rem); /* Desktop: 5 columns */
      }
    }

    .page-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
      border-color: var(--accent);
    }

    :root[data-theme="dark"] .page-card:hover {
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.3);
    }

    .card-image {
      width: 100%;
      height: 150px;
      border-bottom: 1px solid var(--border);
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      margin: 0;
      border: none;
      border-radius: 0;
    }

    .card-content {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      flex-grow: 1;
    }

    .card-content h2 {
      font-size: 1.25rem;
      margin: 0 0 0.5rem 0;
      border-bottom: none;
      padding-bottom: 0;
      color: var(--text);
      transition: color var(--ease);
    }

    .page-card:hover .card-content h2 {
      color: var(--accent);
    }

    .card-content .overview {
      font-size: 0.925rem;
      color: var(--text-muted);
      margin: 0 0 1.25rem 0;
      line-height: 1.6;
      flex-grow: 1;
    }

    .card-meta {
      margin-top: auto;
      font-size: 0.8rem;
      font-family: var(--font-mono);
      color: var(--text-muted);
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
    }

    /* Empty / prompt states */
    .search-prompt,
    .no-results {
      width: 100%; /* Spans full flex row */
      padding: 2.5rem;
      text-align: center;
      color: var(--text-muted);
      background: var(--bg-alt);
      border-radius: var(--radius);
      border: 1px dashed var(--border);
      box-sizing: border-box;
    }

    /* Cards hidden by default */
    #page-grid .page-card {
      display: none;
    }
  </style>
  <script>
    /* search-page.js — client-side filtering */
    (function () {
      "use strict";

      var MIN_CHARS = 3;

      document.addEventListener("DOMContentLoaded", function () {
        var input     = document.getElementById("page-search");
        var grid      = document.getElementById("page-grid");
        var status    = document.getElementById("search-status");
       
        var prompt    = document.getElementById("search-prompt");
        var noResults = document.getElementById("no-results");
        var cards     = Array.prototype.slice.call(grid.querySelectorAll(".page-card"));

        if (!input || !grid) return;

        input.addEventListener("input", function () {
          var raw   = input.value;
          var query = raw.toLowerCase().trim();

          /* Reset state */
          if (raw.length < MIN_CHARS) {
            cards.forEach(function (card) { card.style.display = "none"; });
            prompt.style.display    = "";
            noResults.style.display = "none";
            status.textContent      = "";
            return;
          }

          /* Filter cards */
          prompt.style.display = "none";
          var visible = 0;
          cards.forEach(function (card) {
            var title    = (card.querySelector("h2")       || {}).textContent || "";
            var overview = (card.querySelector(".overview") || {}).textContent || "";

            var match = title.toLowerCase().includes(query) ||
                        overview.toLowerCase().includes(query);

            card.style.display = match ? "flex" : "none";
            if (match) visible++;
          });
          
          noResults.style.display = visible === 0 ? "" : "none";
          status.textContent = visible === 0
            ? ""
            : visible + (visible === 1 ? " result" : " results") + " for '" + raw.trim() + "'";
        });
      });
    })();
  </script>
</head>

<body class="sidebar-hidden">
  <div class="navbar">
    {{block "navbar" .}}{{template "navbar" .}}{{end}}
  </div>

  <main class="content">
    
    <div class="search-hero">
      <h1>Search</h1>

      <div class="search-bar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round"
             aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="page-search"
               placeholder="Type at least 3 characters…"
               autocomplete="off"
               autofocus />
      </div>

      <p>Find anything across all {{len .Pages}} pages.</p>
    </div>

    <p class="search-status" id="search-status" aria-live="polite"></p>

    <div class="page-grid" id="page-grid">
      {{range .Pages}}
      <a href="{{.URL}}" class="page-card">
        {{if .ImgPath}}
        <div class="card-image">
          <img src="{{.ImgPath}}" alt="{{.Title}}" loading="lazy">
        </div>
        {{end}}
        <div class="card-content">
          <h2>{{.Title}}</h2>
          <p class="overview">{{.OverviewText}}</p>
          <div class="card-meta">
            <span class="date">Updated: {{.ModifiedAt}}</span>
          </div>
        </div>
      </a>
      {{end}}

      <div class="search-prompt" id="search-prompt">
        <p>Start typing to search through all pages.</p>
      </div>

      <div class="no-results" id="no-results" style="display:none;">
        <p>No pages match your search.</p>
      </div>
    </div>

  </main>

  <footer class="footer">
    {{block "footer" .}}{{template "footer" .}}{{end}}
  </footer>
</body>

</html>
